var x : int = 9;
var y : real = 10.5;
var z : bool = false;
var resultado : int = 1;
if (x > 0) {
    set resultado = 8;
} else {
    set resultado = 10;
}

def calcular(n : int, o : real) : real {
    if (n > 0) {
        return n * o;
    }
    return 1.5;
}

def funcaoteste(a : int, b : int, c : int): int {
    return a + b + c;
}

print x;

while (resultado > 5) {
    set resultado = resultado - 1;
}
set y = calcular(x, y);
print x;
print y;
print resultado;